{
  "buildCommand": "npm --prefix frontend/frontend run build",
  "devCommand": "npm --prefix frontend/frontend run dev",
  "installCommand": "npm --prefix frontend/frontend install",
  "outputDirectory": "frontend/frontend/dist",
  "crons": [
    {
      "path": "/api/report-automation?mode=daily",
      "schedule": "15 1 * * *"
    },
    {
      "path": "/api/report-automation?mode=weekly",
      "schedule": "40 1 * * 1"
    },
    {
      "path": "/api/report-automation?mode=monthly",
      "schedule": "55 1 1 * *"
    }
  ]
}
